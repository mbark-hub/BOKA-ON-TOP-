    if type ~= "T1" and type ~= "T5" and not _G[type] then for t, s in pairs(TargetStats) do if t ~= "T1" and t ~= "T5" and t ~= type and _G[t] then _G[t] = false; if s then s.Text = "🔴" end end end end
    local wasActive = _G[type]
    _G[type] = not _G[type]
    if stat then stat.Text = _G[type] and "🟢" or "🔴" end
    if wasActive and not _G[type] then
        if type == "T4" or type == "T3" then 
            if Player.Character and Player.Character:FindFirstChild("Humanoid") then Player.Character.Humanoid.Sit = false end
        elseif type == "T6" then 
            if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                if FlingOriginalPos then Player.Character.HumanoidRootPart.CFrame = FlingOriginalPos; FlingOriginalPos = nil end
                Player.Character.Humanoid.PlatformStand = false
            end
        elseif type == "T2" then
            if Player.Character and Player.Character:FindFirstChild("Humanoid") then for _, anim in pairs(Player.Character.Humanoid:GetPlayingAnimationTracks()) do anim:Stop() end end
        end
    end
    if _G[type] and type == "T6" then if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then FlingOriginalPos = Player.Character.HumanoidRootPart.CFrame end end
    task.spawn(function()
        local oldCF = nil
        while _G[type] do
            RunService.Heartbeat:Wait()
            if CurrentTarget and CurrentTarget.Character and Player.Character then
                local tH = CurrentTarget.Character:FindFirstChild("HumanoidRootPart"); local mH = Player.Character:FindFirstChild("HumanoidRootPart")
                if tH and mH then
                    if type == "T1" then 
                        local tool = Player.Character:FindFirstChildOfClass("Tool")
                        if tool then 
                            if not oldCF then oldCF = mH.CFrame end; workspace.CurrentCamera.CameraSubject = CurrentTarget.Character:FindFirstChild("Humanoid")
                            local freq = 40; local dist = 10 + (math.sin(tick() * freq) * 11); mH.Velocity = Vector3.new(0,0,0); mH.CFrame = tH.CFrame * CFrame.new(0, 1.5, dist) 
                        else if oldCF then mH.CFrame = oldCF; workspace.CurrentCamera.CameraSubject = Player.Character.Humanoid; oldCF = nil end end
                    elseif type == "T2" then 
                        for _, anim in pairs(Player.Character.Humanoid:GetPlayingAnimationTracks()) do anim:Stop() end
                        local off = math.sin(tick() * 50) * 0.6; mH.CFrame = tH.CFrame * CFrame.new(0, 0, 0.7 + off)
                    elseif type == "T3" then Player.Character.Humanoid.Sit = true; local freq = 20; local off = math.sin(tick() * freq) * 0.4; mH.CFrame = tH.CFrame * CFrame.new(0, -0.6, off) * CFrame.Angles(math.rad(-45), 0, 0)
                    elseif type == "T4" then Player.Character.Humanoid.Sit = true; local freq = 80; local off = math.sin(tick() * freq) * 0.8; mH.CFrame = tH.CFrame * CFrame.new(0, 1.9, -1.2 + off) * CFrame.Angles(0, math.rad(180), 0)
                    elseif type == "T6" then 
                        Player.Character.Humanoid.PlatformStand = true; local rotation = (tick() * 1000000) % 360; local upDown = math.sin(tick() * 50) * 2
                        mH.CFrame = tH.CFrame * CFrame.new(0, upDown, 1.5) * CFrame.Angles(math.rad(90), math.rad(rotation), 0); mH.Velocity = Vector3.new(0, 1000, 0)
                    elseif type == "T5" then mH.CFrame = CFrame.new(mH.Position, Vector3.new(tH.Position.X, mH.Position.Y, tH.Position.Z))
                    end
                end
            else break end
        end
        pcall(function() if type ~= "T5" then workspace.CurrentCamera.CameraSubject = Player.Character.Humanoid end end)
    end)
end

