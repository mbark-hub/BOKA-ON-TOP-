тАП    local function makeDraggable(frame)
тАП        local dragging = false
тАП        local dragInput = nil
тАП        local dragStart = nil
тАП        local startPos = nil
тАП        local didDrag = false
тАП        local DRAG_THRESHOLD = 6

тАП        local function update(input)
тАП            local delta = input.Position - dragStart
тАП            if math.abs(delta.X) > DRAG_THRESHOLD or math.abs(delta.Y) > DRAG_THRESHOLD then
тАП                didDrag = true
тАП            end
тАП            frame.Position = UDim2.new(
тАП                startPos.X.Scale,
тАП                startPos.X.Offset + delta.X,
тАП                startPos.Y.Scale,
тАП                startPos.Y.Offset + delta.Y
            )
тАП        end

тАП        frame.InputBegan:Connect(function(input)
тАП            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
тАП                dragging = true
тАП                didDrag = false
тАП                dragStart = input.Position
тАП                startPos = frame.Position
тАП                input.Changed:Connect(function()
тАП                    if input.UserInputState == Enum.UserInputState.End then
тАП                        dragging = false
тАП                    end
тАП                end)
тАП            end
тАП        end)

тАП        frame.InputChanged:Connect(function(input)
тАП            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
тАП                dragInput = input
тАП            end
тАП        end)

тАП        UIS.InputChanged:Connect(function(input)
тАП            if dragging and input == dragInput then
тАП                update(input)
тАП            end
тАП        end)

тАП        return function()
тАП            local wasDragged = didDrag
тАП            didDrag = false
тАП            return wasDragged
тАП        end
тАП    end

