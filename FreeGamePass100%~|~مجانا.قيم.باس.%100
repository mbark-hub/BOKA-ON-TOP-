‚Äè    local function makeDraggable(frame)
‚Äè        local dragging = false
‚Äè        local dragInput = nil
‚Äè        local dragStart = nil
‚Äè        local startPos = nil
‚Äè        local didDrag = false
‚Äè        local DRAG_THRESHOLD = 6

‚Äè        local function update(input)
‚Äè            local delta = input.Position - dragStart
‚Äè            if math.abs(delta.X) > DRAG_THRESHOLD or math.abs(delta.Y) > DRAG_THRESHOLD then
‚Äè                didDrag = true
‚Äè            end
‚Äè            frame.Position = UDim2.new(
‚Äè                startPos.X.Scale,
‚Äè                startPos.X.Offset + delta.X,
‚Äè                startPos.Y.Scale,
‚Äè                startPos.Y.Offset + delta.Y
            )
‚Äè        end

‚Äè        frame.InputBegan:Connect(function(input)
‚Äè            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
‚Äè                dragging = true
‚Äè                didDrag = false
‚Äè                dragStart = input.Position
‚Äè                startPos = frame.Position
‚Äè                input.Changed:Connect(function()
‚Äè                    if input.UserInputState == Enum.UserInputState.End then
‚Äè                        dragging = false
‚Äè                    end
‚Äè                end)
‚Äè            end
‚Äè        end)

‚Äè        frame.InputChanged:Connect(function(input)
‚Äè            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
‚Äè                dragInput = input
‚Äè            end
‚Äè        end)

‚Äè        UIS.InputChanged:Connect(function(input)
‚Äè            if dragging and input == dragInput then
‚Äè                update(input)
‚Äè            end
‚Äè        end)

‚Äè        return function()
‚Äè            local wasDragged = didDrag
‚Äè            didDrag = false
‚Äè            return wasDragged
‚Äè        end
‚Äè    end

