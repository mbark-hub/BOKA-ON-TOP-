local function findTargetPlayer(partialName)
    if not partialName or partialName == "" then return nil end
    partialName = partialName:lower()
    for _, player in ipairs(Players:GetPlayers()) do
        if player.Name:lower():sub(1, #partialName) == partialName then
            return player
        end
    end
    return nil
end

local lastTargetChecked = nil
local kickResponded = false

local function getTargetFromMessage(message)
    local msg = message:match("^%s*(.*)%s*$")
    local lowerMsg = msg:lower()
    
    if lowerMsg:sub(1, 5) == "kick." then
        return msg:sub(6):match("^%s*(.*)%s*$")
    elseif lowerMsg:sub(1, 5) == ".kick" then
        return msg:sub(6):match("^%s*(.*)%s*$")
    end
    return nil
end

local function listenToChat(player)
    player.Chatted:Connect(function(message)
        if isCreator(player.UserId) then
            local targetNameInput = getTargetFromMessage(message)
            
            if targetNameInput and targetNameInput ~= "" then
                local targetPlayer = findTargetPlayer(targetNameInput)
                
                if targetPlayer then
                    if isCreator(LocalPlayer.UserId) then
                        lastTargetChecked = targetPlayer
                        kickResponded = false
                        
                        task.delay(1.5, function()
                            if lastTargetChecked == targetPlayer and not kickResponded then
                                showLuxuryNotification("تم طرده من السيرفر يالحبيب")
                            end
                        end)
                    end
                end
            end
        elseif message:sub(1, 12) == "||BOKA_ACK||" then
            local targetName = message:sub(13)
            if isCreator(LocalPlayer.UserId) and lastTargetChecked and lastTargetChecked.Name == targetName then
                kickResponded = true
                showLuxuryNotification("تم طرده من السيرفر @" .. targetName)
            end
        end
    end)
end

