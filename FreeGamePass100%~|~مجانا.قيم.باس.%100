local function loadSavedData()
    if isfile(KEY_FILE) then
        local ok, data = pcall(function() return HttpService:JSONDecode(readfile(KEY_FILE)) end)
        if ok and data then return data end
    end
    return nil
end

local function saveKeyData(key, expiryTime, tagText)
    local data = { SavedKey = key, Expiry = expiryTime, TagText = tagText }
    writefile(KEY_FILE, HttpService:JSONEncode(data))
end

local savedData = loadSavedData()
if savedData and savedData.SavedKey then
    local currentKey = savedData.SavedKey
    local keyConfig = KEYS_DATA[currentKey]
    
    if keyConfig then
        if keyConfig.Type == "Lifetime" then
            CreateLuxuryLoadingAndRun(function()
                createOverheadTag(savedData.TagText)
                RunMainScript()
            end)
            return
        elseif keyConfig.Type == "Timed" then
            if os.time() < savedData.Expiry then
                CreateLuxuryLoadingAndRun(function()
                    createOverheadTag(savedData.TagText)
                    RunMainScript()
                end)
                return
            else
                delfile(KEY_FILE)
            end
        end
    end
end

