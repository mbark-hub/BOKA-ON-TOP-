-- تفعيل السكربت
local Toggled = false
local UpdateLoop

ActivateBtn.MouseButton1Click:Connect(function()
    Toggled = not Toggled
    if Toggled then
        ActivateBtn.Text = (CurrentLanguage == "Arabic") and "🟢 تفعيل" or "🟢 Enabled"
        ActivateBtn.TextColor3 = Color3.new(0, 1, 0)
        
        UpdateLoop = task.spawn(function()
            while Toggled do
                ScanPlayers()
                task.wait(1) 
            end
        end)
    else
        ActivateBtn.Text = (CurrentLanguage == "Arabic") and "🔴 تفعيل" or "🔴 Activate"
        ActivateBtn.TextColor3 = Color3.new(1, 1, 1)
        Toggled = false
        if UpdateLoop then task.cancel(UpdateLoop) end
        RemoveESP()
    end
end)
