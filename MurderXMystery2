local function ApplySilverGlow(stroke)
    task.spawn(function()
        while task.wait() do
            local t = tick() * 2
            local brightness = 0.7 + (math.sin(t) * 0.3)
            stroke.Color = Color3.new(brightness, brightness, brightness)
        end
    end)
end


local function AddButtonStroke(btn)
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 2
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = btn
    ApplySilverGlow(stroke)
end


local function CreateToggle(parent, position, text)
    local Container = Instance.new("TextButton")
    Container.Size = UDim2.new(0, 240, 0, 45)
    Container.Position = position
    Container.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Container.Text = "  " .. text
    Container.TextColor3 = Color3.new(1, 1, 1)
    Container.TextSize = 16
    Container.Font = Enum.Font.GothamBold
    Container.TextXAlignment = Enum.TextXAlignment.Left
    Container.Parent = parent
    Instance.new("UICorner", Container).CornerRadius = UDim.new(0, 8)
    AddButtonStroke(Container)

    local SwitchBg = Instance.new("Frame")
    SwitchBg.Size = UDim2.new(0, 40, 0, 20)
    SwitchBg.Position = UDim2.new(1, -50, 0.5, -10)
    SwitchBg.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    SwitchBg.Parent = Container
    Instance.new("UICorner", SwitchBg).CornerRadius = UDim.new(1, 0)

    local Circle = Instance.new("Frame")
    Circle.Size = UDim2.new(0, 16, 0, 16)
    Circle.Position = UDim2.new(0, 2, 0.5, -8)
    Circle.BackgroundColor3 = Color3.new(1, 1, 1)
    Circle.Parent = SwitchBg
    Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

    local Toggled = false
    local function Toggle(state)
        Toggled = state
        local targetPos = Toggled and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
        local targetColor = Toggled and Color3.fromRGB(100, 150, 255) or Color3.fromRGB(50, 50, 50)
        
        TweenService:Create(Circle, TweenInfo.new(0.2), {Position = targetPos}):Play()
        TweenService:Create(SwitchBg, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
    end

    return Container, function() return Toggled end, Toggle
end

