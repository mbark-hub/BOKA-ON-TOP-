local UpdateLoop
ActivateBtn.MouseButton1Click:Connect(function()
    local state = not IsActivate()
    SetActivate(state)
    if state then
        UpdateLoop = task.spawn(function()
            while IsActivate() do ScanPlayers() task.wait(1) end
        end)
    else
        if UpdateLoop then task.cancel(UpdateLoop) end
        RemoveESP()
    end
end)

