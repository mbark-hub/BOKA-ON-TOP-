local function CreateESP(player, color, roleName)
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local highlight = player.Character:FindFirstChild("BOKA_ESP")
        if not highlight then
            highlight = Instance.new("Highlight")
            highlight.Name = "BOKA_ESP"
            highlight.OutlineColor = Color3.new(1, 1, 1)
            highlight.FillTransparency = 0.5
            highlight.Parent = player.Character
        end
        highlight.Adornee = player.Character
        highlight.FillColor = color

        local billboard = player.Character:FindFirstChild("RoleTag")
        if not billboard then
            billboard = Instance.new("BillboardGui")
            billboard.Name = "RoleTag"
            billboard.Size = UDim2.new(0, 100, 0, 50)
            billboard.AlwaysOnTop = true
            billboard.ExtentsOffset = Vector3.new(0, 3, 0)
            
            local label = Instance.new("TextLabel")
            label.Name = "Label"
            label.Size = UDim2.new(1, 0, 1, 0)
            label.BackgroundTransparency = 1
            label.TextStrokeTransparency = 0
            label.Font = Enum.Font.GothamBold
            label.TextSize = 14
            label.Parent = billboard
            
            billboard.Parent = player.Character
        end
        billboard.Adornee = player.Character:WaitForChild("Head")
        billboard.Label.Text = roleName
        billboard.Label.TextColor3 = color
    end
end

local function RemoveESP()
    for _, v in pairs(Players:GetPlayers()) do
        if v.Character then
            if v.Character:FindFirstChild("BOKA_ESP") then v.Character.BOKA_ESP:Destroy() end
            if v.Character:FindFirstChild("RoleTag") then v.Character.RoleTag:Destroy() end
        end
    end
end

local function ScanPlayers()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character then
            local roleColor = Color3.new(0, 1, 0)
            local roleName = (CurrentLanguage == "Arabic") and "بريء" or "INNOCENT"
            
            if v.Backpack:FindFirstChild("Knife") or v.Character:FindFirstChild("Knife") then
                roleColor = Color3.new(1, 0, 0)
                roleName = (CurrentLanguage == "Arabic") and "قاتل" or "MURDER"
            elseif v.Backpack:FindFirstChild("Gun") or v.Character:FindFirstChild("Gun") then
                roleColor = Color3.new(0, 0, 1)
                roleName = (CurrentLanguage == "Arabic") and "شرف" or "SHERIFF"
            end
            CreateESP(v, roleColor, roleName)
        end
    end
end

local function GetMurderer()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            if v.Backpack:FindFirstChild("Knife") or v.Character:FindFirstChild("Knife") then
                return v.Character.HumanoidRootPart
            end
        end
    end
    return nil
end

local function GetSheriff()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            if v.Backpack:FindFirstChild("Gun") or v.Character:FindFirstChild("Gun") then
                return v.Character
            end
        end
    end
    return nil
end

